          },
          {
            name: "Finn",
            scenario: "is examining angles where a road crosses two parallel railway lines",
            givenAngle: 50,
            correspondingAngle: 50,
            alternateAngle: 50,
            coInteriorAngle: 130
          },
          {
            name: "Nadia",
            scenario: "is studying the angles where a ladder leans across two parallel shelves",
            givenAngle: 72,
            correspondingAngle: 72,
            alternateAngle: 72,
            coInteriorAngle: 108
          }
        ],
        screens: [
          {
            type: "hook",
            title: () => "Parallel lines create equal angles!",
            body: (v) => `${v.name} ${v.scenario}. When a line crosses two **parallel lines** (lines that run in the same direction and never meet), some angles are **exactly equal** and some add to 180°. Let's find the pattern!`,
            visual: {
              component: "WorkedExample",
              props: (v) => ({
                steps: [
                  { text: `Given angle: ${v.givenAngle}°`, why: "One angle is known." },
                  { text: `Corresponding angle: also ${v.correspondingAngle}°`, why: "Same position on the other parallel line — they're equal!" },
                  { text: `Alternate angle: also ${v.alternateAngle}°`, why: "Opposite sides of the crossing line — they're equal too!" }
                ],
                allRevealed: true
              })
            },
            interaction: null
          },
          {
            type: "teach",
            title: () => "Corresponding and alternate angles",
            bodyParts: [
              {
                type: 'text',
                content: () => `When a line (called a **transversal** — the line that crosses both parallel lines) crosses two **parallel lines**, it creates special angle pairs:\n\n**Corresponding angles** (F-shape) = **equal**\n**Alternate angles** (Z-shape) = **equal**\n**Co-interior angles** (C-shape) = add to **180°**`
              },
              {
                type: 'visual',
                component: 'WorkedExample',
                props: (v) => ({
                  steps: [
                    { text: `Corresponding (F-shape): ${v.givenAngle}° = ${v.correspondingAngle}°`, why: "Same position at each crossing — look for an F or backwards F." },
                    { text: `Alternate (Z-shape): ${v.givenAngle}° = ${v.alternateAngle}°`, why: "Opposite sides, between the parallels — look for a Z or S shape." },
                    { text: `Co-interior (C-shape): ${v.givenAngle}° + ${v.coInteriorAngle}° = 180°`, why: "Same side, between the parallels — they add to 180°." }
                  ],
                  allRevealed: false
                })
              },
              {
                type: 'text',
                content: () => `Remember: **F = equal**, **Z = equal**, **C = add to 180°**. ✓`
              }
            ],
            visual: null,
            interaction: {
              type: "match-pairs",
              pairs: (v) => [
                { left: "F-shape (corresponding)", right: "Equal angles" },
                { left: "Z-shape (alternate)", right: "Equal angles" },
                { left: "C-shape (co-interior)", right: "Add to 180°" }
              ]
            }
          },
          {
            type: "interact",
            title: () => "Your turn!",
            body: (v) => `One angle is **${v.givenAngle}°**. What is the **co-interior angle** (the one on the same side, between the parallel lines)?`,
            visual: {
              component: "AngleDisplay",
              props: (v) => ({
                angles: [
                  { value: v.givenAngle, label: `${v.givenAngle}°`, color: "#818cf8" },
                  { value: 180 - v.givenAngle, label: "?°", color: "#d1d5db" }
                ]
              })
            },
            interaction: {
              type: "multiple-choice",
              question: (v) => `What is the co-interior angle?`,
              getOptions: (v) => generateDistractors(v.coInteriorAngle),
              correctAnswer: (v) => v.coInteriorAngle,
              feedback: {
                correct: (v) => `Yes! Co-interior angles add to 180°, so 180° − ${v.givenAngle}° = **${v.coInteriorAngle}°**. ✓`,
                incorrect: (v) => `Not quite! Co-interior angles add to 180°. So 180° − ${v.givenAngle}° = **${v.coInteriorAngle}°**.`
              }
            }
          },
          {
            type: "consolidate",
            title: () => "F, Z, and C — the parallel line letters!",
            body: () => `When you see parallel lines (shown with arrows), look for these letter shapes:`,
            visual: {
              component: "WorkedExample",
              props: () => ({
                steps: [
                  { text: "F-shape → Corresponding angles → EQUAL", why: "Same position at each crossing point." },
                  { text: "Z-shape → Alternate angles → EQUAL", why: "Opposite sides, between the parallels." },
                  { text: "C-shape → Co-interior angles → ADD TO 180°", why: "Same side, between the parallels. ✓" }
                ],
                allRevealed: true
              })
            },
            interaction: null
          }
        ]
      },
      // ---- Lesson B: Key Fact ----
      {
        id: "parallel-lines-keyfact",
        templateType: "key-fact",
        learningGoal: [
          "How to quickly identify which angle rule to use with parallel lines (lines that never meet)",
          "When angles are equal versus when they add to 180°"
        ],
        variableSets: [
          {
            name: "Isaac",
            scenario: "sees an angle of 48° and needs the alternate angle",
            givenAngle: 48,
            targetAngle: 48,
            relationship: "alternate",
            rule: "equal"
          },
          {
            name: "Ella",
            scenario: "sees an angle of 115° and needs the co-interior angle",
            givenAngle: 115,
            targetAngle: 65,
            relationship: "co-interior",
            rule: "add to 180°"
          },
          {
            name: "Jake",
            scenario: "sees an angle of 73° and needs the corresponding angle",
            givenAngle: 73,
            targetAngle: 73,
            relationship: "corresponding",
            rule: "equal"
          }
        ],
        screens: [
          {
            type: "hook",
            title: () => "Equal or add to 180°?",
            body: (v) => `${v.name} ${v.scenario}. The **${v.relationship}** angle — is it **equal** to ${v.givenAngle}°, or does it **add** to 180°? There's an easy way to remember!`,
            visual: {
              component: "WorkedExample",
              props: (v) => ({
                steps: [
                  { text: `Given angle: ${v.givenAngle}°`, why: "" },
                  { text: `Relationship: ${v.relationship}`, why: `These angles ${v.rule}.` }
                ],
