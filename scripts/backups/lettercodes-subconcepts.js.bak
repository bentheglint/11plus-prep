            letterBreakdown: ["V(22) - 3 = S(19)", "Q(17) - 3 = N(14)", "R(18) - 3 = O(15)", "Z(26) - 3 = W(23)"],
            options: ["SNOW", "YTSB", "SLOW", "SNOB", "SHOW"],
