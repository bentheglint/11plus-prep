                  { text: "Code used +N? Decode with -N", why: "+3 → decode with -3" },
                  { text: "Code used -N? Decode with +N", why: "-2 → decode with +2" },
                  { text: "Check: does your answer spell a real word?", why: "If not, recheck each letter ✓" }
                ],
