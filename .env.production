# Production-only build vars (loaded by `react-scripts build`, NOT by
# `react-scripts test` — so committing the freemium flag here turns the
# free-tier UI on for prod builds without breaking the unit tests that
# assert the flag defaults off). Overlays .env at build time.
#
# Phase 0 freemium rollout (8 Jul 2026): flips the client-side free-tier
# gating on (locked cards, daily-set cap, upgrade prompts, trial-end
# interstitial). Server enforcement is separate (app_settings kill-switch).
REACT_APP_FF_FREETIER=true
