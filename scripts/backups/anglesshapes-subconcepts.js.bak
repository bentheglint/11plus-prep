                ]
              })
            },
            interaction: {
              type: "multiple-choice",
              question: (v) => `What is the missing angle?`,
              getOptions: (v) => generateDistractors(v.missingAngle),
              correctAnswer: (v) => v.missingAngle,
              feedback: {
                correct: (v) => `Brilliant! **180° − ${v.knownAngle}° = ${v.missingAngle}°**. ✓`,
                incorrect: (v) => `Not quite! Angles on a straight line add up to 180°. So the missing angle is 180° − ${v.knownAngle}° = **${v.missingAngle}°**.`
              }
            }
          },
          {
            type: "consolidate",
            title: () => "The straight line rule!",
            body: () => `Whenever angles sit on a **straight line**, they add up to **180°**.`,
            visual: {
              component: "WorkedExample",
              props: () => ({
                steps: [
                  { text: "Step 1: Spot that the angles are on a straight line", why: "Look for angles that share a flat base line." },
                  { text: "Step 2: Add up all the angles you know", why: "There might be two, three, or more angles on the line." },
                  { text: "Step 3: Subtract from 180°", why: "The leftover is the missing angle. ✓" }
                ],
                allRevealed: true
              })
            },
            interaction: null
          }
