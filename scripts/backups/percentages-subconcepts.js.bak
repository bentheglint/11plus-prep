            visual: {
              component: "BarModel",
              props: (v) => ({
                segments: Array.from({ length: 10 }, (_, i) => ({
                  value: 1,
                  label: i === 0 ? `${v.unit}${v.tenPercent}` : "",
                  color: i < Math.floor(v.targetPercent / 10) ? "#c084fc" : "#e5e7eb",
