            shapeName: "hexagon",
            sides: 6,
            angleSum: 720,
            knownAngles: [135, 110, 125, 140, 100],
            knownSum: 610,
            missingAngle: 110
          },
          {
            name: "Priya",
            scenario: "is working out the missing angle in a quadrilateral for her maths test",
            shapeName: "quadrilateral",
            sides: 4,
            angleSum: 360,
            knownAngles: [85, 110, 70],
            knownSum: 265,
            missingAngle: 95
          }
        ],
        screens: [
          {
            type: "hook",
            title: (v) => `What's the missing angle in this ${v.shapeName}?`,
            body: (v) => `${v.name} ${v.scenario}. The ${v.shapeName} has **${v.sides} sides** and the known angles are **${v.knownAngles.join('°, ')}°**. One angle is missing!`,
            visual: {
              component: "WorkedExample",
              props: (v) => ({
                steps: [
                  { text: `Shape: irregular ${v.shapeName} (${v.sides} sides)`, why: "Not regular — the angles are all different." },
                  { text: `Known angles: ${v.knownAngles.join('°, ')}°`, why: `That's ${v.knownAngles.length} out of ${v.sides} angles.` },
                  { text: "One angle is missing — we need to find it!", why: "" }
                ],
                allRevealed: true
              })
            },
            interaction: null
          },
          {
            type: "teach",
            title: () => "Use the rule, then subtract!",
            bodyParts: [
              {
                type: 'text',
                content: (v) => `First, find the **total** of all interior angles using **(n − 2) × 180°**.\n\nThen **add up** the angles you know and **subtract** from the total.`
              },
              {
                type: 'text',
                content: (v) => `**Irregular ${v.shapeName}** (${v.sides} sides):\nAngles: ${v.knownAngles.map(a => '**' + a + '°**').join(', ')}, **?°**\nAngle sum = (${v.sides} − 2) × 180° = **${v.angleSum}°**`
              },
              {
                type: 'visual',
                component: 'WorkedExample',
                props: (v) => ({
                  steps: [
                    { text: `Step 1: Angle sum = (${v.sides} − 2) × 180° = ${v.sides - 2} × 180° = ${v.angleSum}°`, why: "Use this rule for any polygon." },
                    { text: `Step 2: Add known angles: ${v.knownAngles.join('° + ')}° = ${v.knownSum}°`, why: "Add them up carefully." },
                    { text: `Step 3: Missing angle = ${v.angleSum}° − ${v.knownSum}° = ${v.missingAngle}°`, why: "Subtract to find what's left. ✓" }
                  ],
                  allRevealed: true
                })
              },
              {
                type: 'text',
                content: (v) => `The missing angle is **${v.missingAngle}°**. ✓`
              }
            ],
            visual: null,
            interaction: {
              type: "order-steps",
              steps: (v) => [
                `Find the angle sum: (${v.sides} − 2) × 180° = ${v.angleSum}°`,
                `Add the known angles: ${v.knownSum}°`,
                `Subtract: ${v.angleSum}° − ${v.knownSum}° = ${v.missingAngle}°`
              ],
              feedback: {
                correct: (v) => `Perfect order! Find the total, add the known angles, then subtract. ✓`,
                incorrect: (v) => `Not quite — first find the total using (n − 2) × 180°, then add the known angles, then subtract.`
              }
            }
          },
          {
            type: "interact",
            title: () => "Your turn!",
            body: (v) => `An irregular ${v.shapeName} has angles of **${v.knownAngles.join('°, ')}°** and one unknown. What is the missing angle?`,
            visual: {
              component: "WorkedExample",
              props: (v) => ({
                steps: [
                  { text: `Angle sum of a ${v.shapeName}: ${v.angleSum}°`, why: `(${v.sides} − 2) × 180°` },
                  { text: `Known angles add up to: ${v.knownSum}°`, why: `${v.knownAngles.join('° + ')}°` }
                ],
                allRevealed: true
              })
            },
            interaction: {
              type: "multiple-choice",
              question: (v) => `What is the missing angle?`,
              getOptions: (v) => generateDistractors(v.missingAngle),
              correctAnswer: (v) => v.missingAngle,
              feedback: {
                correct: (v) => `Yes! ${v.angleSum}° − ${v.knownSum}° = **${v.missingAngle}°**. ✓`,
                incorrect: (v) => `Not quite. Total = ${v.angleSum}°. Known = ${v.knownSum}°. So missing = ${v.angleSum}° − ${v.knownSum}° = **${v.missingAngle}°**.`
              }
            }
          },
          {
            type: "consolidate",
            title: () => "The 3-step method for missing angles!",
            body: () => `This works for **any** polygon — regular or irregular:`,
            visual: {
              component: "WorkedExample",
              props: () => ({
                steps: [
                  { text: "Step 1: Find the total — (n − 2) × 180°", why: "n = number of sides." },
                  { text: "Step 2: Add up all the angles you know", why: "Be careful with the addition!" },
                  { text: "Step 3: Subtract from the total", why: "Total − known angles = missing angle. ✓" }
                ],
                allRevealed: true
              })
            },
            interaction: null
          }
        ]
      },
