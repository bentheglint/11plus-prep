# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build

# misc
.DS_Store
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.dev.vars
**/.dev.vars

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Claude Code config (user-specific, not project source).
# Ignore everything in .claude/ by default, then selectively re-include
# project-portable content (skills + agents intended to travel with the repo).
/.claude/*
!/.claude/skills/
/.claude/skills/*
!/.claude/skills/pricing-advisor/
!/.claude/agents/
/.claude/agents/*
!/.claude/agents/pricing-advisor.md

# Cloudflare
/.wrangler

# Visual QA screenshots (large, regenerable)
/visual-qa-screenshots
/visual-qa-audit

# API keys and secrets
/Master Brief Document and Working Instructions/Claude API Key

# Research library — track text (.md) only; scan/binary subfolders stay ignored below
/research/**
!/research/**/
!/research/**/*.md

# Scanned reference materials (large binary files)
/Examples for English and VR
/research/kingsbury
/research/maths-reference
/research/past-papers
/Micro-Lesson Research
/Lesson Plan Examples
/difficulty-scores

# Progress tracker screenshots (large binary files)
/Progress Tracker Content

# Temp/working files
_tmp_*
_diagram-audit/
dev-review-notes.json

# D1 backups + staging copies — contain sensitive user data, never commit
/backups/*.sql
/backups/*.sql.gpg
/backups/*.sql.gz
/backups/*.db

# Wrangler local state (nested)
workers/**/.wrangler

# Batch processing scripts (one-off, not app code)
scripts/bias-batch-*
scripts/oracle-batch-*
scripts/comprehension-length-bias.json
scripts/write-remaining-batches.js

# Recovery toolkit generated artefacts (regenerable from scripts/recovery/*.py)
/recovery-output

# Process-gate artefacts (Plan A v2.1 — produced by scripts/process-gates/*.mjs)
# Contain row counts, schema fingerprints, Worker SHA. Regenerable by re-running
# the relevant script. Hooks read these locally; not needed in version control.
/process-gate-artefacts

# Audit outputs — generated by audit scripts, not source
/brand-assets/mobile-audit
/scripts/validation/lint-report.json

# Dev-only rendered email previews (scripts/preview-emails.mjs) — regenerable, never committed
/demo-preview
