                  { text: `10% of ${v.unit}${v.amount} = ${v.unit}${v.tenPercent}`, why: `${v.unit}${v.amount} \u00f7 10` },
                  { text: `5% = ${v.unit}${v.fivePercent}`, why: `Half of ${v.unit}${v.tenPercent}` },
                  { text: `1% = ${v.unit}${v.onePercent}`, why: `${v.unit}${v.amount} \u00f7 100` },
