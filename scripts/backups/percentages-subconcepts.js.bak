                correct: (v) => `Brilliant! ${v.targetPercent}% = ${v.buildDesc} = ${v.buildCalc} = **${v.unit}${v.answer}${v.unitAfter}**. ✓`,
                incorrect: (v) => `Not quite! ${v.targetPercent}% = ${v.buildDesc}. That's ${v.buildCalc} = **${v.unit}${v.answer}${v.unitAfter}**.`
