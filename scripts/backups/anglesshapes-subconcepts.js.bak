            body: () => `Just remember which angle pairs are **equal** and which **add to 180°**:`,
            visual: {
              component: "WorkedExample",
              props: () => ({
                steps: [
                  { text: "Corresponding (F-shape) → EQUAL", why: "Same position, same angle." },
                  { text: "Alternate (Z-shape) → EQUAL", why: "Opposite sides, same angle." },
                  { text: "Co-interior (C-shape) → ADD TO 180°", why: "Same side, they add up to a straight line. ✓" }
