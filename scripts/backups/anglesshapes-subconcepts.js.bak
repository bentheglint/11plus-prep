  // ==========================================
  // SUB-CONCEPT 10: Polygon Angles
  // ==========================================
  {
    id: "polygon-angles",
    name: "Interior Angles of Regular Polygons",
    category: "other",
    lessons: [
      // ---- Lesson A: Step-by-Step ----
      {
        id: "polygon-angles-steps",
        templateType: "step-by-step",
        learningGoal: [
          "How to calculate the sum of interior angles (inside angles) using (n - 2) x 180°",
          "How to find one angle in a regular polygon (a shape where all sides and angles are equal)"
        ],
        variableSets: [
          {
            name: "Priya",
            scenario: "is calculating angles in a regular pentagon for a tiling project",
            shapeName: "pentagon",
            sides: 5,
            triangles: 3,
            angleSum: 540,
            eachAngle: 108
          },
          {
            name: "Tom",
            scenario: "is working out the interior angle of a regular hexagon for a bee honeycomb project",
            shapeName: "hexagon",
            sides: 6,
            triangles: 4,
            angleSum: 720,
            eachAngle: 120
          },
          {
            name: "Daisy",
            scenario: "is finding angles in a regular octagon (stop sign shape)",
            shapeName: "octagon",
            sides: 8,
            triangles: 6,
            angleSum: 1080,
            eachAngle: 135
          }
        ],
        screens: [
          {
            type: "hook",
            title: (v) => `What's each angle in a regular ${v.shapeName}?`,
            body: (v) => `${v.name} ${v.scenario}. A ${v.shapeName} has **${v.sides} sides**. In a **regular** polygon, all angles are equal — but what are they?`,
            visual: {
              component: "WorkedExample",
              props: (v) => ({
                steps: [
                  { text: `Shape: regular ${v.shapeName}`, why: `${v.sides} sides, all equal.` },
                  { text: `We need: each interior angle`, why: "All angles are the same in a regular polygon." }
                ],
                allRevealed: true
              })
            },
            interaction: null
          },
          {
            type: "teach",
            title: () => "The (n - 2) x 180° rule",
            bodyParts: [
              {
                type: 'text',
                content: (v) => `Any polygon can be split into **triangles** by drawing diagonals from one corner. A ${v.shapeName} splits into **${v.triangles} triangles**.\n\nEach triangle = 180°, so the total = **${v.triangles} x 180° = ${v.angleSum}°**.`
              },
              {
                type: 'text',
                content: (v) => `**Triangulation:** ${v.shapeName} (${v.sides} sides)  →  ${v.triangles} triangles  →  ${v.triangles} × 180° = **${v.angleSum}°**\nRegular shape: each angle = ${v.angleSum}° ÷ ${v.sides} = **${v.eachAngle}°**`
              },
              {
                type: 'visual',
                component: 'WorkedExample',
                props: (v) => ({
                  steps: [
                    { text: `Number of sides (n): ${v.sides}`, why: `Count the sides of the ${v.shapeName}.` },
                    { text: `Number of triangles: ${v.sides} − 2 = ${v.triangles}`, why: "Always 2 fewer triangles than sides." },
                    { text: `Angle sum: ${v.triangles} × 180° = ${v.angleSum}°`, why: "Each triangle contributes 180°." },
                    { text: `Each angle: ${v.angleSum}° ÷ ${v.sides} = ${v.eachAngle}°`, why: "All angles equal in a regular polygon. ✓" }
                  ],
                  allRevealed: false
                })
              },
              {
                type: 'text',
                content: (v) => `Each interior angle of a regular ${v.shapeName} is **${v.eachAngle}°**. ✓`
              }
            ],
            visual: null,
            interaction: {
              type: "match-pairs",
              pairs: (v) => [
                { left: "Triangle (3 sides)", right: "180°" },
                { left: "Quadrilateral (4 sides)", right: "360°" },
                { left: `${v.shapeName} (${v.sides} sides)`, right: `${v.angleSum}°` }
              ]
            }
          },
          {
            type: "interact",
            title: () => "Your turn!",
            body: (v) => `A regular ${v.shapeName} has ${v.sides} sides. What is each interior angle?`,
            visual: {
              component: "WorkedExample",
              props: (v) => ({
                steps: [
                  { text: `Triangles: ${v.sides} − 2 = ${v.triangles}`, why: "" },
                  { text: `Total angle sum: ${v.triangles} × 180° = ${v.angleSum}°`, why: "" }
                ],
                allRevealed: true
              })
            },
            interaction: {
              type: "multiple-choice",
              question: (v) => `What is each interior angle?`,
              getOptions: (v) => generateDistractors(v.eachAngle),
              correctAnswer: (v) => v.eachAngle,
              feedback: {
                correct: (v) => `Yes! ${v.angleSum}° ÷ ${v.sides} = **${v.eachAngle}°**. ✓`,
                incorrect: (v) => `Not quite! Angle sum = (${v.sides} − 2) × 180° = ${v.angleSum}°. Then ${v.angleSum}° ÷ ${v.sides} = **${v.eachAngle}°**.`
              }
            }
          },
          {
            type: "consolidate",
            title: () => "The polygon angle rule!",
            body: () => `For **any** polygon, this rule works:`,
            visual: {
              component: "WorkedExample",
              props: () => ({
                steps: [
                  { text: "Step 1: Count the sides (n)", why: "Pentagon = 5, hexagon = 6, octagon = 8, etc." },
                  { text: "Step 2: Angle sum = (n − 2) × 180°", why: "Split into triangles — always 2 fewer than the number of sides." },
                  { text: "Step 3: For REGULAR polygons, divide by n", why: "All angles are equal, so share the total equally. ✓" }
                ],
                allRevealed: true
              })
            },
            interaction: null
          }
        ]
      },
