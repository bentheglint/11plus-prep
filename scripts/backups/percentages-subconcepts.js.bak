            visual: {
              component: "BarModel",
              props: (v) => ({
                segments: [
                  { value: 10, label: "10%?", color: "#fbbf24" },
                  { value: 90, label: "", color: "#e5e7eb", empty: true }
                ],
                totalLabel: `${v.unit}${v.amount}${v.unitAfter}`,
                showValues: true
              })
            },
            interaction: {
              type: "multiple-choice",
              question: (v) => `10% of ${v.unit}${v.amount} = ?`,
              getOptions: (v) => generateDistractors(v.tenPercent),
              correctAnswer: (v) => v.tenPercent,
              feedback: {
                correct: (v) => `Yes! ${v.unit}${v.amount} ÷ 10 = **${v.unit}${v.tenPercent}**. You've unlocked the master building block! ✓`,
                incorrect: (v) => `Not quite! Divide by 10: ${v.unit}${v.amount} ÷ 10 = **${v.unit}${v.tenPercent}**.`
              }
            }
          },
          {
            type: "consolidate",
            title: () => "10% is the master building block!",
            body: () => `Once you can find 10%, the rest is just adding and halving:`,
            visual: {
              component: "WorkedExample",
              props: () => ({
                steps: [
                  { text: "10% = divide by 10", why: "This is the one trick you MUST know" },
                  { text: "From 10% you can get 20% (×2), 30% (×3), etc.", why: "Just multiply your 10% answer" },
                  { text: "From 10% you can get 5% (halve it)", why: "And even 1% by dividing 10% by 10 ✓" }
                ],
                allRevealed: true
              })
            },
            interaction: null
          }
        ]
      }
