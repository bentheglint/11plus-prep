            body: (v) => `What is **${v.part}** out of **${v.whole}** as a percentage?`,
            visual: {
              component: "BarModel",
              props: (v) => ({
                segments: [
                  { value: v.part, label: `${v.part}`, color: "#c084fc" },
                  { value: v.whole - v.part, label: "", color: "#e5e7eb", empty: true }
                ],
                totalLabel: `${v.whole} total`,
                showValues: true
              })
            },
            interaction: {
              type: "multiple-choice",
              question: (v) => `${v.part} out of ${v.whole} as a percentage?`,
              getOptions: (v) => generateDistractors(v.correctAnswer),
              correctAnswer: (v) => v.correctAnswer,
              feedback: {
                correct: (v) => `Spot on! (${v.part} \u00f7 ${v.whole}) \u00d7 100 = **${v.correctAnswer}%**. ✓`,
                incorrect: (v) => `Not quite! (${v.part} \u00f7 ${v.whole}) \u00d7 100 = **${v.correctAnswer}%**.`
              }
            }
          },
          {
            type: "consolidate",
            title: () => "Avoid these common traps!",
            body: () => `When expressing as a percentage, always remember:`,
            visual: {
              component: "WorkedExample",
              props: () => ({
                steps: [
                  { text: "Divide PART by WHOLE (not the other way round!)", why: "The smaller number usually goes on top" },
                  { text: "Don't forget to multiply by 100", why: "0.3 is NOT the same as 0.3% — it's 30%!" },
                  { text: "The part alone is NOT the percentage", why: "9 out of 50 is not 9% — it's 18% ✓" }
                ],
                allRevealed: true
              })
            },
            interaction: null
          }
        ]
      }
    ]
  },

  // ==========================================
  // SUB-CONCEPT 6: percentage-increase
  // Percentage increase (find %, then add)
  // Category: supporting
  // Lesson A: step-by-step | Lesson B: curiosity-hook
  // ==========================================
  {
    id: "percentage-increase",
    name: "Percentage Increase",
    category: "supporting",
    lessons: [
      // ---- Lesson A: Step by Step ----
      {
        id: "percentage-increase-step",
        templateType: "step-by-step",
        learningGoal: [
          "How to calculate a price after a percentage increase",
          "Why you find the percentage first, then add"
        ],
        variableSets: [
          {
            name: "A toy shop",
            scenario: "increases prices by 20% after Christmas. A board game was",
            original: 30, percent: 20,
            increase: 6, newPrice: 36,
            tenPercent: 3,
            unit: "\u00a3"
          },
          {
            name: "A landlord",
            scenario: "raises the rent by 10%. The rent was",
            original: 800, percent: 10,
            increase: 80, newPrice: 880,
            tenPercent: 80,
            unit: "\u00a3"
          },
          {
            name: "A bakery",
            scenario: "puts up the price of bread by 25%. A loaf was",
            original: 2, percent: 25,
            increase: 0.5, newPrice: 2.5,
            tenPercent: 0.2,
            unit: "\u00a3"
          }
        ],
        screens: [
          {
            type: "hook",
            title: (v) => `${v.percent}% increase on ${v.unit}${v.original}`,
            body: (v) => `${v.name} ${v.scenario} **${v.unit}${v.original}**.\n\nWhat's the new price after a **${v.percent}% increase**? Let's work it out step by step!`,
            visual: {
              component: "BarModel",
              props: (v) => ({
                segments: [
                  { value: 100, label: `Original: ${v.unit}${v.original}`, color: "#818cf8" },
                  { value: v.percent, label: `+${v.percent}%`, color: "#34d399" }
                ],
                totalLabel: `Original + increase = new price`,
                showValues: true
              })
            },
            interaction: null
          },
          {
            type: "teach",
            title: () => "Find the %, then add it on!",
            body: (v) => `Percentage increase is a two-step process:\n\n1. **Find the percentage** of the original amount (use the building-block method: 10%, 5%, 1%)\n2. **ADD** the percentage to the original — increase means it gets bigger\n3. **Check:** your answer should be MORE than you started with\n\nTap to see each step!`,
            visual: {
              component: "WorkedExample",
              props: (v) => ({
                steps: [
                  { text: `Find ${v.percent}% of ${v.unit}${v.original}`, why: `10% = ${v.unit}${v.tenPercent}, so ${v.percent}% = ${v.unit}${v.increase}`, result: `Increase = ${v.unit}${v.increase}` },
                  { text: `Add to the original`, why: `${v.unit}${v.original} + ${v.unit}${v.increase}`, result: `New price = ${v.unit}${v.newPrice} ✓` }
                ],
                allRevealed: false
              })
            },
            interaction: { type: "tap-to-reveal" }
          },
          {
            type: "interact",
            title: () => "Your turn!",
            body: (v) => `What is **${v.unit}${v.original}** after a **${v.percent}% increase**?`,
            visual: {
              component: "BarModel",
              props: (v) => ({
                segments: [
                  { value: 100, label: `${v.unit}${v.original}`, color: "#818cf8" },
                  { value: v.percent, label: `+${v.percent}%?`, color: "#34d399" }
                ],
                showValues: true
              })
            },
            interaction: {
              type: "multiple-choice",
              question: (v) => `${v.unit}${v.original} increased by ${v.percent}% = ?`,
              getOptions: (v) => generateDistractors(v.newPrice),
              correctAnswer: (v) => v.newPrice,
              feedback: {
                correct: (v) => `Brilliant! ${v.percent}% of ${v.unit}${v.original} = ${v.unit}${v.increase}. Add it on: ${v.unit}${v.original} + ${v.unit}${v.increase} = **${v.unit}${v.newPrice}**. ✓`,
                incorrect: (v) => `Not quite! ${v.percent}% = ${v.unit}${v.increase}. Then add: ${v.unit}${v.original} + ${v.unit}${v.increase} = **${v.unit}${v.newPrice}**.`
              }
            }
          },
          {
            type: "consolidate",
            title: () => "Percentage increase — the recipe",
            body: () => `Remember: find the percentage, then ADD it on.`,
            visual: {
              component: "WorkedExample",
              props: () => ({
                steps: [
                  { text: "1. Find 10% by dividing by 10", why: "This is your building block" },
                  { text: "2. Scale up to the percentage you need", why: "e.g. 30% = 10% × 3" },
                  { text: "3. ADD the percentage to the original", why: "Increase means it gets bigger" },
                  { text: "4. Check: is your answer bigger than the original?", why: "If not, you subtracted instead of added! ✓" }
                ],
                allRevealed: true
              })
            },
            interaction: null
          }
        ]
      },

      // ---- Lesson B: Curiosity Hook ----
      {
